{
  "name": "@openleash/client-api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    }
  },
  "scripts": {
    "predev": "npm run build -w @openleash/shared",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run build -w @openleash/shared",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build -w @openleash/shared",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/agent-events.test.ts src/plugin-icon-input.test.ts src/plugin-icons.test.ts src/plugins/dangerous-code/index.test.ts",
    "db:migrate": "tsx src/migrate.ts",
    "db:load-plugins": "tsx src/load-plugins.ts"
  },
  "dependencies": {
    "@openleash/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.19.2",
    "openai": "^4.104.0",
    "pg": "^8.13.3",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.11.14",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
